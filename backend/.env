# Server
PORT=3001
NODE_ENV=production

# MySQL Database
DB_HOST=localhost
DB_PORT=3307
DB_USER=hyperv_panel
DB_PASSWORD=hyperv_panel
DB_NAME=hyperv_panel

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES=604800

# PowerShell
PS_EXECUTION_POLICY=Bypass

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Brute force
LOGIN_LOCKOUT_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Default admin username (password is auto-generated on first run and printed to console)
# Only takes effect if no users exist in the database yet.
DEFAULT_ADMIN_USER=admin

# VM root paths (semicolon-separated Windows paths)
VM_ROOTS=C:\Vms;D:\HyperV\Virtual Machines;D:\Vms